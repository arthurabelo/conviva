# Server
HOST=0.0.0.0
PORT=8000
# HTTP request logging (0=off, 1=on)
CONVIVA_HTTP_LOG=0
# Auth/session
# 86400 seconds = 24 hours
SESSION_EXPIRE_SECONDS=86400
SECRET_KEY=conviva-local-demo-secret

# Database (PostgreSQL/Supabase)
# Prefer STORAGE_POSTGRES_URL on Vercel Supabase integration, or DATABASE_URL locally.
